<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">

    <!-- Nome da unidade de persistência (você usará esse nome no código Java) -->
    <persistence-unit name="taskPersistence" transaction-type="RESOURCE_LOCAL">
        
        <!-- Classe da entidade (opcional listar aqui, mas é boa prática) -->
        <!-- <class>br.com.seuprojeto.modelo.Usuario</class> -->

        <properties>
            <!-- Configurações de Conexão com o Banco -->
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://172.17.0.2:3306/taskmanager?useSSL=false&amp;serverTimezone=UTC&amp;allowPublicKeyRetrieval=true"/>
            
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="admin"/>

            <!-- Configurações do Hibernate -->
            <!-- Dialeto para MySQL 8 (no Hibernate 6, MySQLDialect já é otimizado para MySQL 8+) -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
            
            <!-- Geração do esquema do banco: 'update' cria/atualiza tabelas automaticamente (use 'validate' ou 'none' em produção) -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            
            <!-- Mostrar os comandos SQL no console (útil para desenvolvimento) -->
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="false"/>

            <!-- Integração com HikariCP (Opcional, mas recomendado) -->
            <property name="hibernate.connection.provider_class" value="org.hibernate.hikaricp.internal.HikariCPConnectionProvider"/>
            <property name="hibernate.hikari.minimumIdle" value="5"/>
            <property name="hibernate.hikari.maximumPoolSize" value="20"/>
        </properties>
    </persistence-unit>
</persistence>